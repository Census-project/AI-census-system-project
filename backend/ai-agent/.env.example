# Google Gemini API key — powers the AI reasoning layer via Google ADK.
# Get one free at https://aistudio.google.com/apikey
# The agent runs fine WITHOUT this — all geospatial/satellite/temporal checks
# still execute and a rule-based verdict is produced. With the key set, Gemini
# additionally reasons over the same signals for richer, more nuanced verdicts.
GEMINI_API_KEY=

# Which Gemini model ADK should use.
ADK_MODEL=gemini-2.5-flash

# Port this FastAPI service listens on. Must match AI_AGENT_URL in the Node backend's .env.
AI_AGENT_PORT=8001
